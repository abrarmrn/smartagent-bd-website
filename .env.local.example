# Copy this file to .env.local (local dev) and set the same vars in Vercel.
# Production domain: https://smartagentbd.online

# n8n webhook that receives lead-capture form submissions (server-side only).
# The contact/demo form POSTs JSON to this URL via the /api/lead route.
# LIVE production webhook for SmartAgent BD:
LEAD_WEBHOOK_URL=https://abrarpial94.app.n8n.cloud/webhook/smartagent-lead

# --- Public contact handles used by CTA buttons (safe to expose) ---
# Facebook page username or numeric id for m.me deep link, e.g. "SmartAgentBD"
NEXT_PUBLIC_MESSENGER_HANDLE=
# WhatsApp number in international format, digits only, e.g. "8801XXXXXXXXX"
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Phone number for tel: link, e.g. "+8801XXXXXXXXX"
NEXT_PUBLIC_PHONE_NUMBER=
